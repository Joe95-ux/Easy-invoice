generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  BUSINESS
  SCALE
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PAID
  OVERDUE
  CANCELLED
}

enum EstimateStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum ReminderKind {
  BEFORE_DUE
  ON_DUE
  OVERDUE
  MANUAL
}

enum ReminderDeliveryStatus {
  SENT
  FAILED
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  country   String   @default("US")
  taxId     String?
  logoUrl   String?
  currency  String   @default("USD")
  locale    String   @default("en")
  plan      Plan     @default(FREE)
  defaultTemplateId String?
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  remindersEnabled     Boolean  @default(true)
  reminderDaysBefore   Int[]    @default([7, 3])
  reminderOnDueDate    Boolean  @default(true)
  reminderDaysAfter    Int[]    @default([1, 7, 14])
  reminderIncludePdf   Boolean  @default(true)
  defaultHourlyRate    Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   CompanyMember[]
  invites   CompanyInvite[]
  clients   Client[]
  invoices  Invoice[]
  estimates Estimate[]
  templates InvoiceTemplate[]
  defaultTemplate InvoiceTemplate? @relation("CompanyDefaultTemplate", fields: [defaultTemplateId], references: [id], onDelete: SetNull)
  timeEntries TimeEntry[]

  @@index([slug])
}

model CompanyMember {
  id           String    @id @default(cuid())
  companyId    String
  clerkId      String
  email        String
  role         UserRole  @default(MEMBER)
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sentInvites CompanyInvite[] @relation("SentInvites")
  timeEntries TimeEntry[]

  @@unique([companyId, clerkId])
  @@index([clerkId])
}

model CompanyInvite {
  id          String    @id @default(cuid())
  companyId   String
  email       String
  role        UserRole  @default(MEMBER)
  token       String    @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy CompanyMember @relation("SentInvites", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([email])
}

model Client {
  id        String   @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  country   String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices Invoice[]
  estimates Estimate[]
  timeEntries TimeEntry[]

  @@index([companyId])
}

model Invoice {
  id            String        @id @default(cuid())
  companyId     String
  clientId      String?
  number        String
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  currency      String        @default("USD")
  subtotal      Decimal       @default(0) @db.Decimal(12, 2)
  taxRate       Decimal       @default(0) @db.Decimal(5, 4)
  taxAmount     Decimal       @default(0) @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @default(0) @db.Decimal(12, 2)
  notes         String?
  customFields  Json?
  templateId    String?
  sentAt        DateTime?
  paidAt        DateTime?
  viewedAt      DateTime?
  publicToken   String?       @unique
  sourceEstimateId String?    @unique
  remindersPaused  Boolean      @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client    Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  template  InvoiceTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sourceEstimate Estimate?    @relation("EstimateToInvoice", fields: [sourceEstimateId], references: [id], onDelete: SetNull)
  items     InvoiceLineItem[]
  reminders InvoiceReminder[]
  timeEntries TimeEntry[]

  @@unique([companyId, number])
  @@index([companyId, status])
}

model InvoiceReminder {
  id           String                 @id @default(cuid())
  invoiceId    String
  kind         ReminderKind
  offsetDays   Int                    @default(0)
  scheduleDate DateTime               @db.Date
  toEmail      String
  status       ReminderDeliveryStatus @default(SENT)
  error        String?
  createdAt    DateTime               @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, kind, offsetDays, scheduleDate])
  @@index([invoiceId])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 4)
  unitPrice   Decimal @default(0) @db.Decimal(12, 2)
  amount      Decimal @default(0) @db.Decimal(12, 2)
  sortOrder   Int     @default(0)

  invoice    Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  @@index([invoiceId])
}

model TimeEntry {
  id                String    @id @default(cuid())
  companyId         String
  clientId          String?
  memberId          String?
  description       String
  date              DateTime  @db.Date
  durationMinutes   Int
  hourlyRate        Decimal   @db.Decimal(12, 2)
  billable          Boolean   @default(true)
  invoiceId         String?
  invoiceLineItemId String?
  invoicedAt        DateTime?
  externalSource    String?
  externalId        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client          Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  member          CompanyMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  invoice         Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  invoiceLineItem InvoiceLineItem? @relation(fields: [invoiceLineItemId], references: [id], onDelete: SetNull)

  @@index([companyId, invoicedAt])
  @@index([companyId, clientId])
  @@index([invoiceId])
  @@unique([companyId, externalSource, externalId])
}

model Estimate {
  id            String         @id @default(cuid())
  companyId     String
  clientId      String?
  number        String
  status        EstimateStatus @default(DRAFT)
  issueDate     DateTime       @default(now())
  validUntil    DateTime?
  currency      String         @default("USD")
  subtotal      Decimal        @default(0) @db.Decimal(12, 2)
  taxRate       Decimal        @default(0) @db.Decimal(5, 4)
  taxAmount     Decimal        @default(0) @db.Decimal(12, 2)
  discount      Decimal        @default(0) @db.Decimal(12, 2)
  total         Decimal        @default(0) @db.Decimal(12, 2)
  notes         String?
  customFields  Json?
  templateId    String?
  sentAt        DateTime?
  acceptedAt    DateTime?
  viewedAt      DateTime?
  publicToken   String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client   Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  template InvoiceTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  convertedInvoice Invoice? @relation("EstimateToInvoice")
  items    EstimateLineItem[]

  @@unique([companyId, number])
  @@index([companyId, status])
}

model EstimateLineItem {
  id          String  @id @default(cuid())
  estimateId  String
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 4)
  unitPrice   Decimal @default(0) @db.Decimal(12, 2)
  amount      Decimal @default(0) @db.Decimal(12, 2)
  sortOrder   Int     @default(0)

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

model InvoiceTemplate {
  id        String   @id @default(cuid())
  companyId String?
  name      String
  slug      String
  isDefault Boolean  @default(false)
  isSystem  Boolean  @default(false)
  html      String   @db.Text
  css       String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  defaultForCompanies Company[] @relation("CompanyDefaultTemplate")
  invoices Invoice[]
  estimates Estimate[]

  @@unique([companyId, slug])
}
