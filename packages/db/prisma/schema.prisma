generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Plan {
  FREE
  PRO
  BUSINESS
  SCALE
}

enum InvoiceStatus {
  DRAFT
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentMethod {
  CASH
  CHECK
  BANK_TRANSFER
  CARD
  OTHER
}

enum EstimateStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

enum UserRole {
  OWNER
  ADMIN
  MEMBER
}

enum ReminderKind {
  BEFORE_DUE
  ON_DUE
  OVERDUE
  MANUAL
}

enum ReminderDeliveryStatus {
  SENT
  FAILED
}

enum DocumentType {
  INVOICE
  ESTIMATE
}

enum DocumentRevisionSource {
  CREATE
  EDIT
  RESTORE
  STATUS
  SEND
  VIEWED
  REMINDER
  PAYMENT_CONFIRMATION
}

enum AuditCategory {
  TEAM
  SETTINGS
  DOCUMENT
}

enum NotificationType {
  CLIENT_VIEWED_INVOICE
  CLIENT_VIEWED_ESTIMATE
  ESTIMATE_ACCEPTED
  ESTIMATE_DECLINED
  PAYMENT_RECEIVED
  INVOICE_OVERDUE
  TEAM_INVITE_RECEIVED
  MEMBER_ROLE_CHANGED
}

enum AuditAction {
  MEMBER_INVITED
  MEMBER_INVITE_CANCELLED
  MEMBER_JOINED
  MEMBER_ROLE_CHANGED
  MEMBER_REMOVED
  COMPANY_PROFILE_UPDATED
  COMPANY_LOGO_UPLOADED
  COMPANY_LOGO_REMOVED
  REMINDER_SETTINGS_UPDATED
  DEFAULT_TEMPLATE_CHANGED
  INVOICE_DELETED
  ESTIMATE_DELETED
  CLIENT_DELETED
  PAYMENT_CONFIRMATION_SENT
  PAYMENT_CONFIRMATION_RESENT
}

model Company {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  country   String   @default("US")
  taxId     String?
  logoUrl        String?
  logoBg         String   @default("white")
  logoPlacement  String   @default("watermark")
  brandColor     String?
  currency  String   @default("USD")
  locale    String   @default("en")
  plan      Plan     @default(FREE)
  defaultTemplateId String?
  stripeCustomerId     String? @unique
  stripeSubscriptionId String? @unique
  remindersEnabled     Boolean  @default(true)
  reminderDaysBefore   Int[]    @default([7, 3])
  reminderOnDueDate    Boolean  @default(true)
  reminderDaysAfter    Int[]    @default([1, 7, 14])
  reminderIncludePdf   Boolean  @default(true)
  paymentReceiptEmailsEnabled Boolean @default(true)
  documentPrefix       String?
  invoiceSequence      Int      @default(0)
  estimateSequence     Int      @default(0)
  receiptSequence      Int      @default(0)
  defaultHourlyRate    Decimal? @db.Decimal(12, 2)
  timerRoundToMinutes  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members   CompanyMember[]
  invites   CompanyInvite[]
  clients   Client[]
  invoices  Invoice[]
  estimates Estimate[]
  templates InvoiceTemplate[]
  defaultTemplate InvoiceTemplate? @relation("CompanyDefaultTemplate", fields: [defaultTemplateId], references: [id], onDelete: SetNull)
  timeEntries TimeEntry[]
  activeTimeTimers ActiveTimeTimer[]
  documentRevisions DocumentRevision[]
  auditEvents       AuditEvent[]
  notifications     Notification[]

  @@index([slug])
}

model CompanyMember {
  id           String    @id @default(cuid())
  companyId    String
  clerkId      String
  email        String
  name         String?
  role         UserRole  @default(MEMBER)
  lastActiveAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  notifyClientViewed     Boolean @default(true)
  notifyEstimateResponse Boolean @default(true)
  notifyPaymentReceived  Boolean @default(true)
  notifyInvoiceOverdue   Boolean @default(true)
  notifyTeamChanges      Boolean @default(true)
  celebrateInvoicePaid   Boolean @default(false)

  company     Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  sentInvites CompanyInvite[] @relation("SentInvites")
  timeEntries TimeEntry[]
  activeTimeTimer ActiveTimeTimer?
  documentRevisions DocumentRevision[]
  invoicePayments InvoicePayment[]
  paymentConfirmationEmails PaymentConfirmationEmail[]
  auditEvents       AuditEvent[]
  notifications     Notification[]

  @@unique([companyId, clerkId])
  @@index([clerkId])
}

model CompanyInvite {
  id          String    @id @default(cuid())
  companyId   String
  email       String
  role        UserRole  @default(MEMBER)
  token       String    @unique
  invitedById String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())

  company   Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invitedBy CompanyMember @relation("SentInvites", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([email])
}

model Client {
  id        String   @id @default(cuid())
  companyId String
  name      String
  email     String?
  phone     String?
  address   String?
  city      String?
  state     String?
  zip       String?
  country   String?
  notes     String?
  defaultHourlyRate Decimal? @db.Decimal(12, 2)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  invoices Invoice[]
  estimates Estimate[]
  timeEntries TimeEntry[]
  activeTimeTimers ActiveTimeTimer[]

  @@index([companyId])
}

model ActiveTimeTimer {
  id          String   @id @default(cuid())
  companyId   String
  memberId    String   @unique
  clientId    String?
  description String
  startedAt   DateTime
  billable    Boolean  @default(true)
  hourlyRate  Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  member  CompanyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)
  client  Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([companyId])
}

model Invoice {
  id            String        @id @default(cuid())
  companyId     String
  clientId      String?
  number        String
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  dueDate       DateTime?
  currency      String        @default("USD")
  subtotal      Decimal       @default(0) @db.Decimal(12, 2)
  taxRate       Decimal       @default(0) @db.Decimal(5, 4)
  taxAmount     Decimal       @default(0) @db.Decimal(12, 2)
  discount      Decimal       @default(0) @db.Decimal(12, 2)
  total         Decimal       @default(0) @db.Decimal(12, 2)
  notes         String?
  customFields  Json?
  templateId    String?
  sentAt        DateTime?
  paidAt        DateTime?
  viewedAt      DateTime?
  publicToken   String?       @unique
  sourceEstimateId String?    @unique
  remindersPaused  Boolean      @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  company   Company           @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client    Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  template  InvoiceTemplate?  @relation(fields: [templateId], references: [id], onDelete: SetNull)
  sourceEstimate Estimate?    @relation("EstimateToInvoice", fields: [sourceEstimateId], references: [id], onDelete: SetNull)
  items     InvoiceLineItem[]
  reminders InvoiceReminder[]
  installments InvoiceInstallment[]
  payments  InvoicePayment[]
  timeEntries TimeEntry[]

  @@unique([companyId, number])
  @@index([companyId, status])
}

model InvoiceReminder {
  id           String                 @id @default(cuid())
  invoiceId    String
  kind         ReminderKind
  offsetDays   Int                    @default(0)
  scheduleDate DateTime               @db.Date
  toEmail      String
  status       ReminderDeliveryStatus @default(SENT)
  error        String?
  createdAt    DateTime               @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@unique([invoiceId, kind, offsetDays, scheduleDate])
  @@index([invoiceId])
}

model InvoiceInstallment {
  id        String   @id @default(cuid())
  invoiceId String
  dueDate   DateTime
  amount    Decimal  @db.Decimal(12, 2)
  label     String?
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model InvoicePayment {
  id            String        @id @default(cuid())
  invoiceId     String
  memberId      String?
  receiptNumber String?       @unique
  publicToken   String?       @unique
  amount        Decimal       @db.Decimal(12, 2)
  paidAt        DateTime      @default(now())
  method        PaymentMethod @default(OTHER)
  reference     String?
  note          String?
  createdAt     DateTime      @default(now())

  invoice             Invoice                    @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  member              CompanyMember?             @relation(fields: [memberId], references: [id], onDelete: SetNull)
  confirmationEmails  PaymentConfirmationEmail[]

  @@index([invoiceId])
}

model PaymentConfirmationEmail {
  id        String                 @id @default(cuid())
  paymentId String
  memberId  String?
  toEmail   String
  isResend  Boolean                @default(false)
  status    ReminderDeliveryStatus @default(SENT)
  error     String?
  createdAt DateTime               @default(now())

  payment InvoicePayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)
  member  CompanyMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@index([createdAt])
}

model InvoiceLineItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 4)
  unitPrice   Decimal @default(0) @db.Decimal(12, 2)
  amount      Decimal @default(0) @db.Decimal(12, 2)
  sortOrder   Int     @default(0)

  invoice    Invoice     @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  timeEntries TimeEntry[]

  @@index([invoiceId])
}

model TimeEntry {
  id                String    @id @default(cuid())
  companyId         String
  clientId          String?
  memberId          String?
  description       String
  date              DateTime  @db.Date
  durationMinutes   Int
  hourlyRate        Decimal   @db.Decimal(12, 2)
  billable          Boolean   @default(true)
  invoiceId         String?
  invoiceLineItemId String?
  invoicedAt        DateTime?
  externalSource    String?
  externalId        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  company         Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client          Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  member          CompanyMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  invoice         Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: SetNull)
  invoiceLineItem InvoiceLineItem? @relation(fields: [invoiceLineItemId], references: [id], onDelete: SetNull)

  @@index([companyId, invoicedAt])
  @@index([companyId, clientId])
  @@index([invoiceId])
  @@unique([companyId, externalSource, externalId])
}

model Estimate {
  id            String         @id @default(cuid())
  companyId     String
  clientId      String?
  number        String
  status        EstimateStatus @default(DRAFT)
  issueDate     DateTime       @default(now())
  validUntil    DateTime?
  currency      String         @default("USD")
  subtotal      Decimal        @default(0) @db.Decimal(12, 2)
  taxRate       Decimal        @default(0) @db.Decimal(5, 4)
  taxAmount     Decimal        @default(0) @db.Decimal(12, 2)
  discount      Decimal        @default(0) @db.Decimal(12, 2)
  total         Decimal        @default(0) @db.Decimal(12, 2)
  notes         String?
  customFields  Json?
  templateId    String?
  sentAt        DateTime?
  acceptedAt    DateTime?
  viewedAt      DateTime?
  publicToken   String?        @unique
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client   Client?          @relation(fields: [clientId], references: [id], onDelete: SetNull)
  template InvoiceTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  convertedInvoice Invoice? @relation("EstimateToInvoice")
  items    EstimateLineItem[]

  @@unique([companyId, number])
  @@index([companyId, status])
}

model EstimateLineItem {
  id          String  @id @default(cuid())
  estimateId  String
  description String
  quantity    Decimal @default(1) @db.Decimal(12, 4)
  unitPrice   Decimal @default(0) @db.Decimal(12, 2)
  amount      Decimal @default(0) @db.Decimal(12, 2)
  sortOrder   Int     @default(0)

  estimate Estimate @relation(fields: [estimateId], references: [id], onDelete: Cascade)

  @@index([estimateId])
}

model InvoiceTemplate {
  id        String   @id @default(cuid())
  companyId String?
  name      String
  slug      String
  isDefault Boolean  @default(false)
  isSystem  Boolean  @default(false)
  html      String   @db.Text
  css       String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  company  Company?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  defaultForCompanies Company[] @relation("CompanyDefaultTemplate")
  invoices Invoice[]
  estimates Estimate[]

  @@unique([companyId, slug])
}

model DocumentRevision {
  id             String                 @id @default(cuid())
  companyId      String
  documentType   DocumentType
  documentId     String
  revisionNumber Int
  snapshot       Json?
  summary        String
  source         DocumentRevisionSource
  memberId       String?
  metadata       Json?
  createdAt      DateTime               @default(now())

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  member  CompanyMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@unique([documentType, documentId, revisionNumber])
  @@index([companyId, documentType, documentId])
  @@index([documentId])
}

model AuditEvent {
  id         String        @id @default(cuid())
  companyId  String
  memberId   String?
  category   AuditCategory
  action     AuditAction
  summary    String
  entityType String?
  entityId   String?
  metadata   Json?
  createdAt  DateTime      @default(now())

  company Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  member  CompanyMember? @relation(fields: [memberId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt(sort: Desc)])
  @@index([companyId, category, createdAt(sort: Desc)])
}

model Notification {
  id        String           @id @default(cuid())
  companyId String
  memberId  String
  type      NotificationType
  title     String
  body      String
  linkUrl   String?
  metadata  Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())

  company Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  member  CompanyMember @relation(fields: [memberId], references: [id], onDelete: Cascade)

  @@index([memberId, read, createdAt(sort: Desc)])
  @@index([companyId])
}
