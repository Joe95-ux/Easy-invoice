# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://easyinvoice:easyinvoice@localhost:5432/easyinvoice"

# ── Clerk (https://dashboard.clerk.com) ───────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/onboarding

# ── Stripe (https://dashboard.stripe.com) ─────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ── OpenAI (used by Python ai-docs service) ───────────────
OPENAI_API_KEY=

# ── Python ai-docs service ────────────────────────────────
AI_DOCS_SERVICE_URL=http://localhost:8000
AI_DOCS_SERVICE_SECRET=change-me-in-production

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
